# =====================================================
# 心芽 · 环境配置文件
# 说明：这个文件存放程序运行需要的"密钥"和"配置"
# 上传到服务器时，需要填写真实的值
# =====================================================

# 数据库连接地址（PostgreSQL）
# 格式：postgresql://用户名:密码@地址:端口/数据库名
DATABASE_URL="postgresql://xinya:你的数据库密码@localhost:5432/xinya_db"

# JWT密钥（用于登录验证，随机字母数字即可，越长越安全）
JWT_SECRET="请替换成一个随机字符串比如xinya2026abcdef"

# 邮件发送配置（QQ邮箱免费SMTP）
# SMTP_USER 填你的QQ邮箱地址
# SMTP_PASS 填QQ邮箱的"授权码"（不是登录密码，需要在QQ邮箱设置里生成）
SMTP_USER="你的QQ邮箱@qq.com"
SMTP_PASS="你的QQ邮箱授权码"

# 网站访问地址（开发时是localhost，部署后改成你的域名）
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# 硅基流动 AI API密钥（后续填写）
SILICONFLOW_API_KEY=""
