generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  isVerified    Boolean  @default(false)
  theme         String   @default("spring")
  onboardDone   Boolean  @default(false)
  openTimes     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  entries        Entry[]
  tags           Tag[]
  shares         Share[]
  insightReports InsightReport[]
  aiInsights     AiInsight[]
  growthLogs     GrowthLog[]
  emailTokens    EmailToken[]
  settings       UserSetting?
  quizRecords    QuizRecord[]
  reviewCallLogs ReviewCallLog[]
}

model Entry {
  id          String    @id @default(cuid())
  userId      String
  title       String
  content     String
  keyPoints   String?
  mood        String?
  recordTime  DateTime  @default(now())
  isTop       Boolean   @default(false)
  isFavorite  Boolean   @default(false)
  isDraft     Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags        Tag[]     @relation("EntryTags")
  quizQuestions QuizQuestion[]

  @@index([userId, recordTime(sort: Desc)])
  @@index([userId, isTop])
  @@index([userId, isFavorite])
  @@index([userId, isDraft])
}

model Tag {
  id        String   @id @default(cuid())
  userId    String
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries   Entry[]  @relation("EntryTags")

  @@unique([userId, name])
  @@index([userId])
}

model Share {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique @default(cuid())
  expiresAt DateTime
  scope     String    @default("all")
  tagIds    String[]  @default([])
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AiInsight {
  id           String   @id @default(cuid())
  userId       String
  content      String
  triggerCount Int
  isRead       Boolean  @default(false)
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

model InsightReport {
  id          String   @id @default(cuid())
  userId      String
  type        String
  periodStart DateTime
  periodEnd   DateTime
  content     Json
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, periodStart])
  @@index([userId, type])
}

model GrowthLog {
  id        String   @id @default(cuid())
  userId    String?
  version   String
  title     String
  content   String
  logDate   DateTime
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  type      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model MagicLink {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
  @@index([email])
}

model QuizQuestion {
  id          String   @id @default(cuid())
  entryId     String
  question    String
  type        String
  options     Json
  answer      Json
  explanation String
  angle       Int      @default(1)
  createdAt   DateTime @default(now())

  entry       Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  records     QuizRecord[]

  @@index([entryId])
}

model QuizRecord {
  id            String   @id @default(cuid())
  userId        String
  questionId    String
  entryId       String
  correct       Boolean
  answeredAt    DateTime?
  nextReviewAt  DateTime
  streak        Int      @default(0)

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question      QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([userId, nextReviewAt])
  @@index([userId, questionId])
}

model UserSetting {
  id              String  @id @default(cuid())
  userId          String  @unique
  reviewEnabled   Boolean @default(false)
  lastCardDate    String?
  lastQuestionId  String?

  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ReviewCallLog {
  id          String   @id @default(cuid())
  userId      String
  entryId     String?
  step        String   // "pre-generate" | "cache-hit" | "online-retry" | "template-fallback"
  success     Boolean
  questionCount Int    @default(0)
  errorMsg    String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}